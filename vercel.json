{
  "version": 2,
  "framework": null,
  "outputDirectory": "frontend/webapp",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 10
    }
  },
  "env": {
    "BOT_TOKEN": "@skillverse-bot-token"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
